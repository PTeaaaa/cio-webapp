generator client {
  provider = "prisma-client-js"
  binaryTarget = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String      @id @default(uuid())
  cardId            String?     @unique
  username          String      @unique
  password          String
  role              String
  
  //Information collected
  name              String?
  surname           String?
  email             String?
  phone             String?
  position          String?

  isActive          Boolean     @default(true)
  rememberMe        Boolean     @default(true)
  rememberMeSession Boolean?

  sessionId         String?     @unique
  sessionExpiredAt  DateTime?
  sessionRevokedAt  DateTime?
  refreshToken      String?     @unique
  refreshTokenExpiresAt DateTime?

  // Security tracking
  lastLoginAt       DateTime?
  lockedUntil       DateTime?
  passwordChangedAt DateTime?
  
  // Audit trail
  createdBy         String?
  createdByAccount  Account?  @relation("AccountCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  modifiedBy        String?
  modifiedByAccount Account?  @relation("AccountModifiedBy", fields: [modifiedBy], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt @default(now())

  assignedPlaces    AccountPlace[]
  
  // Self-referential relations for audit trail
  accountsCreated   Account[] @relation("AccountCreatedBy")
  accountsModified  Account[] @relation("AccountModifiedBy")

  @@map("accounts")
}

model Place {
  id                String  @id @default(uuid())
  name              String  @unique
  agency            String
  numberOrder       Int     @default(0)

  people            PersonPlacement[]
  assignedAccounts  AccountPlace[]

  @@map("places")
}

model AccountPlace {
  id          Int     @id @default(autoincrement())
  account     Account @relation(fields: [accountId], references: [id])
  accountId   String
  place       Place   @relation(fields: [placeId], references: [id])
  placeId     String

  @@unique([accountId,placeId])
  @@map("account_place")
}

model Person {
  id          String   @id @unique @default(uuid())
  prefix      String?
  name        String
  surname     String
  email       String?
  phone       String?
  position    String?
  imageUrl    String?
  placeId     String?
  department  String
  year        Int

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  modifiedBy  String? // New Column, don't forget to make a new migrate

  placements  PersonPlacement[]

  @@unique([name, surname, year])
  @@map("people")
}

model PersonPlacement {
  id          Int     @id @default(autoincrement())
  person      Person  @relation(fields: [personId], references: [id])
  personId    String
  place       Place   @relation(fields: [placeId], references: [id])
  placeId     String

  @@unique([personId,placeId])
  @@map("person_placements")
}